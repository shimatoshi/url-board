{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/resolve/:project",
      "destination": "/api/resolve/[project]?project=:project"
    },
    {
      "source": "/go/:project",
      "destination": "/go/[project]?project=:project"
    }
  ]
}
